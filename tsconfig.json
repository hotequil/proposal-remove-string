{
  "compilerOptions": {
    "outDir": "dist/",
    "target": "ES2024",
    "module": "commonjs",
    "lib": ["ES2024", "DOM"],
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "downlevelIteration": true,
    "declaration": true,
    "sourceMap": true
  },
  "include": ["polyfill/index.ts"],
  "exclude": ["polyfill/*.spec.ts"]
}
